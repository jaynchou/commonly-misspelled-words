:root {
  color-scheme: light;
  --paper: #f7f3ea;
  --paper-fiber: #eee7d8;
  --ink: #1f1b16;
  --muted: #746b60;
  --line: #d8cebd;
  --accent: #8d2f22;
  --accent-ink: #fff9f4;
  --panel: #fffaf1;
  --shadow: 0 16px 50px rgb(51 35 18 / 0.09);
  --ui-font: Georgia, "Iowan Old Style", "Palatino Linotype", Palatino, serif;
}

[data-theme="dark"] {
  color-scheme: dark;
  --paper: #15130f;
  --paper-fiber: #201c16;
  --ink: #f0e9db;
  --muted: #b7aa98;
  --line: #3d352a;
  --accent: #d67b5f;
  --accent-ink: #20130f;
  --panel: #1d1a15;
  --shadow: 0 18px 60px rgb(0 0 0 / 0.28);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--paper);
  overflow-x: hidden;
}

body {
  margin: 0;
  overflow-x: hidden;
  color: var(--ink);
  background:
    radial-gradient(circle at 20% 10%, rgb(0 0 0 / 0.035) 0 1px, transparent 1px) 0 0 / 18px 18px,
    radial-gradient(circle at 80% 30%, rgb(255 255 255 / 0.35) 0 1px, transparent 1px) 0 0 / 23px 23px,
    linear-gradient(90deg, rgb(0 0 0 / 0.028) 1px, transparent 1px) 0 0 / 42px 42px,
    linear-gradient(0deg, color-mix(in srgb, var(--paper-fiber) 42%, transparent), transparent 38%),
    var(--paper);
  font-family: Georgia, "Iowan Old Style", "Palatino Linotype", Palatino, serif;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input {
  font: inherit;
}

:focus-visible {
  outline: 3px solid color-mix(in srgb, var(--accent) 72%, white);
  outline-offset: 3px;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 22px;
  align-items: center;
  padding: 18px clamp(18px, 4vw, 56px);
  border-bottom: 1px solid var(--line);
  background: color-mix(in srgb, var(--paper) 92%, transparent);
}

.brand {
  display: flex;
  gap: 12px;
  align-items: center;
}

.brand-mark {
  display: grid;
  place-items: center;
  position: relative;
  width: 42px;
  height: 42px;
  border: 2px solid var(--ink);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--line) 70%, transparent);
  font-weight: 700;
  line-height: 1;
}

.brand-mark span {
  font-size: 1.5rem;
}

.brand-mark i {
  position: absolute;
  right: 7px;
  bottom: 5px;
  color: var(--accent);
  font-size: 1rem;
  font-style: italic;
}

.brand strong {
  display: block;
  font-size: 1.2rem;
}

.brand small,
.kicker,
.eyebrow {
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 0.73rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: end;
  gap: 18px;
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 0.96rem;
  font-weight: 700;
}

nav a:hover,
.footer-nav a:hover {
  color: var(--accent);
}

.icon-button,
.secondary-button,
.primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--panel);
  color: var(--ink);
  cursor: pointer;
}

.icon-button {
  width: 40px;
  border: 0;
  border-radius: 6px;
  background: transparent;
  box-shadow: none;
}

.icon-button svg {
  stroke-width: 2.3;
}

.primary-button {
  padding: 0 20px;
  border-color: var(--accent);
  background: var(--accent);
  color: var(--accent-ink);
  font-family: var(--ui-font);
  font-weight: 700;
}

.secondary-button {
  padding: 0 18px;
  font-family: var(--ui-font);
  font-weight: 700;
}

.mobile-menu {
  display: none;
}

.mobile-menu button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  min-height: 40px;
  padding: 0;
  border: 0;
  border-radius: 6px;
  background: transparent;
  color: var(--ink);
  cursor: pointer;
  font-family: var(--ui-font);
  box-shadow: none;
}

.mobile-menu button svg {
  stroke-width: 2.2;
}

.mobile-menu nav {
  position: absolute;
  top: calc(100% + 10px);
  right: 0;
  z-index: 20;
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  justify-content: stretch;
  justify-items: stretch;
  width: min(148px, calc(100vw - 28px));
  gap: 0;
  padding: 6px 4px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: var(--shadow);
}

.mobile-menu nav a {
  display: grid;
  place-items: center;
  width: 100%;
  min-height: 40px;
  padding: 0;
  border-radius: 6px;
  font-family: var(--ui-font);
  font-size: 0.92rem;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.mobile-menu nav a:hover {
  background: color-mix(in srgb, var(--line) 38%, transparent);
}

.container {
  width: min(1280px, calc(100% - 28px));
  margin: 0 auto;
}

.wide-container {
  width: min(1480px, calc(100% - 28px));
  margin: 0 auto;
}

.hero {
  display: block;
  padding: clamp(18px, 4vw, 42px) 0 10px;
}

.hero-copy {
  border-top: 3px double var(--ink);
  border-bottom: 1px solid var(--line);
  padding: 20px 0;
}

h1,
h2,
h3 {
  margin: 0;
  text-wrap: balance;
}

h1 {
  max-width: 960px;
  font-size: clamp(2rem, 4.4vw, 4.4rem);
  line-height: 1.02;
}

.hero-line {
  max-width: none;
  overflow: hidden;
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  line-height: 1.12;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quiz-title {
  max-width: 100%;
  overflow-wrap: normal;
  font-size: clamp(1.35rem, 2vw, 1.95rem);
  line-height: 1.04;
  white-space: normal;
}

h2 {
  font-size: clamp(1.45rem, 2vw, 2.25rem);
  line-height: 1.08;
}

h3 {
  font-size: 1.35rem;
}

p {
  color: var(--muted);
  line-height: 1.7;
  text-wrap: pretty;
}

.deck {
  max-width: 680px;
  font-size: 1.12rem;
}

.challenge-band {
  padding: 4px 0 22px;
}

.play-layout {
  display: grid;
  grid-template-columns: minmax(0, 620px) 220px;
  gap: 14px;
  align-items: stretch;
  width: min(854px, calc(100% - 28px));
  margin: 0 auto;
  min-width: 0;
}

.play-layout > .quiz-shell {
  grid-column: 1;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  margin-top: 24px;
  border: 1px solid var(--line);
  background: var(--line);
}

.stat {
  background: var(--panel);
  padding: 18px;
}

.stat b {
  display: block;
  font-size: 1.7rem;
  font-variant-numeric: tabular-nums;
}

.quiz-shell,
.panel {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: var(--shadow);
}

.quiz-shell {
  min-width: 0;
  padding: 16px;
}

.quiz-top {
  display: flex;
  min-width: 0;
  justify-content: space-between;
  gap: 16px;
  border-bottom: 1px solid var(--line);
  padding-bottom: 16px;
}

.quiz-top > div:first-child {
  min-width: 0;
  flex: 1 1 auto;
}

.quiz-word {
  margin: 18px 0 8px;
  font-size: clamp(1.35rem, 1.9vw, 1.95rem);
  line-height: 1.06;
}

.choices {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 260px));
  justify-content: center;
  gap: 12px 14px;
}

.choice {
  width: 100%;
  min-height: 48px;
  padding: 12px 16px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: transparent;
  color: var(--ink);
  text-align: center;
  cursor: pointer;
}

.choice:hover,
.choice.selected {
  border-color: var(--accent);
}

.choice.correct {
  background: #e8f2de;
  color: #18350d;
}

.choice.wrong {
  background: #f7dfd9;
  color: #4a120a;
}

.quiz-actions,
.form-row {
  display: flex;
  gap: 10px;
  align-items: center;
  margin-top: 18px;
}

.form-row input {
  min-width: 0;
  flex: 0 1 280px;
  min-height: 42px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: var(--paper);
  color: var(--ink);
  padding: 0 16px;
}

.finish-note {
  margin-bottom: 0;
  max-width: none;
  font-size: 1rem;
  white-space: nowrap;
}

.finish-actions {
  display: grid;
  gap: 12px;
}

.share-open-button {
  width: fit-content;
}

.share-icon-button {
  width: 42px;
  min-width: 42px;
  padding: 0;
}

.answer-review {
  display: grid;
  gap: 10px;
  margin-top: 2px;
}

.answer-review h3 {
  font-size: 1.05rem;
}

.answer-review > div {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.answer-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 6px 9px;
  font-family: var(--ui-font);
  font-size: 0.82rem;
}

.correct-pill {
  background: #e8f2de;
  color: #18350d;
}

.wrong-pill {
  background: #f7dfd9;
  color: #4a120a;
  text-decoration: line-through;
  text-decoration-thickness: 2px;
}

.share-overlay {
  position: fixed;
  inset: 0;
  z-index: 30;
  display: grid;
  place-items: center;
  padding: 28px;
}

.share-backdrop {
  position: fixed;
  inset: 0;
  border: 0;
  background: rgb(23 19 15 / 0.62);
  backdrop-filter: blur(8px);
  cursor: pointer;
}

.share-modal {
  position: relative;
  z-index: 1;
  width: min(760px, 100%);
  max-height: min(92vh, 980px);
  overflow-y: auto;
  border-radius: 18px;
  background: var(--paper);
  box-shadow: 0 28px 90px rgb(0 0 0 / 0.35);
  padding: 30px;
  text-align: center;
}

.share-close {
  position: absolute;
  top: 18px;
  right: 18px;
  display: grid;
  width: 38px;
  height: 38px;
  place-items: center;
  border: 0;
  background: transparent;
  color: var(--muted);
  cursor: pointer;
}

.share-modal h2 {
  margin-top: 4px;
  font-size: clamp(1.7rem, 3vw, 2.6rem);
}

.share-subtitle {
  max-width: none;
  margin: 8px 0 22px;
  font-family: var(--ui-font);
  font-size: 1rem;
}

.share-card {
  display: grid;
  gap: 18px;
  width: min(560px, 100%);
  margin: 0 auto;
  border-radius: 12px;
  background:
    radial-gradient(circle at 20% 0%, rgb(159 47 35 / 0.22), transparent 34%),
    linear-gradient(135deg, #181a2c, #10131f 55%, #231625);
  color: #fffaf1;
  padding: 28px;
  text-align: left;
}

.share-card .eyebrow,
.share-card p {
  color: rgb(255 250 241 / 0.7);
}

.share-card h3 {
  margin-top: 6px;
  font-size: clamp(1.55rem, 3vw, 2.25rem);
}

.share-score-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  overflow: hidden;
  border-radius: 10px;
  background: rgb(255 250 241 / 0.22);
}

.share-score-row div {
  display: grid;
  gap: 4px;
  background: #fffaf1;
  color: #17130f;
  padding: 14px;
}

.share-score-row span,
.share-score-row small {
  color: #756d63;
  font-family: var(--ui-font);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
}

.share-score-row strong {
  font-size: 2rem;
  line-height: 1;
}

.share-words {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.share-words span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 999px;
  padding: 7px 10px;
  font-family: var(--ui-font);
  font-size: 0.82rem;
  font-weight: 700;
}

.share-word-correct {
  background: rgb(232 242 222 / 0.16);
  color: #d8f2c8;
}

.share-word-wrong {
  background: rgb(247 223 217 / 0.16);
  color: #ffd5cc;
  text-decoration: line-through;
  text-decoration-thickness: 2px;
}

.share-cta {
  border: 1px solid rgb(255 250 241 / 0.2);
  border-radius: 10px;
  background: #9f2f23;
  padding: 16px;
  font-size: 1.25rem;
  font-weight: 700;
  text-align: center;
}

.share-label {
  margin: 22px 0 12px;
  font-family: var(--ui-font);
  font-weight: 700;
}

.share-socials {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
}

.share-socials button {
  display: grid;
  gap: 7px;
  min-width: 70px;
  place-items: center;
  border: 0;
  background: transparent;
  color: var(--ink);
  font-family: var(--ui-font);
  font-weight: 700;
  cursor: pointer;
}

.share-socials svg {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  padding: 12px;
  fill: currentColor;
  box-shadow: 0 10px 24px rgb(0 0 0 / 0.12);
}

.share-socials span {
  color: var(--muted);
  font-size: 0.78rem;
}

.share-socials .whatsapp svg {
  background: #25d366;
  color: #fff;
}

.share-socials .facebook svg {
  background: #1877f2;
  color: #fff;
}

.share-socials .instagram svg {
  background: linear-gradient(135deg, #f58529, #dd2a7b 45%, #8134af 72%, #515bd4);
  color: #fff;
}

.share-socials .tiktok svg {
  background: #111;
  color: #fff;
}

.share-socials .x-social svg {
  background: #000;
  color: #fff;
}

.share-socials .reddit svg {
  background: #ff4500;
  color: #fff;
}

.share-socials .more-social svg {
  border: 1px solid var(--line);
  background: var(--panel);
  color: var(--ink);
}

.share-tools {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-top: 18px;
}

.share-status {
  margin: 12px 0 0;
  color: var(--accent);
  font-family: var(--ui-font);
  font-weight: 700;
}

.form-error {
  margin: 10px 0 0;
  color: var(--accent);
  font-family: var(--ui-font);
  font-size: 0.92rem;
}

.progress {
  overflow: hidden;
  height: 8px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--line) 70%, transparent);
}

.progress span {
  display: block;
  height: 100%;
  background: var(--accent);
}

.start-panel {
  display: grid;
  min-height: 132px;
  align-content: center;
  justify-items: start;
  text-align: left;
}

.start-button {
  min-width: min(210px, 100%);
  min-height: 42px;
  margin-top: 12px;
  font-size: 0.9rem;
}

.timer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18px;
  color: var(--muted);
  font-family: var(--ui-font);
}

.timer-row strong {
  display: grid;
  place-items: center;
  min-width: 48px;
  height: 48px;
  border: 1px solid var(--accent);
  border-radius: 50%;
  color: var(--accent);
  font-variant-numeric: tabular-nums;
}

.section {
  padding: 32px 0;
}

.section-header {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 18px;
  min-width: 0;
  margin-bottom: 20px;
  border-top: 1px solid var(--line);
  padding-top: 18px;
}

.section-header > div {
  min-width: 0;
}

.section-header .secondary-button {
  flex: 0 0 auto;
  white-space: nowrap;
}

.section-header.compact {
  margin-bottom: 8px;
  padding-top: 0;
  border-top: 0;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.panel {
  padding: 20px;
}

.leaderboard-card {
  grid-column: 2;
  align-self: stretch;
  position: sticky;
  top: 92px;
  display: flex;
  min-height: 100%;
  flex-direction: column;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: var(--shadow);
  padding: 12px;
}

.leaderboard-card h3 {
  font-size: 1.18rem;
  line-height: 1.05;
}

@media (max-width: 1120px) {
  .play-layout {
    grid-template-columns: 1fr;
  }

  .play-layout > .quiz-shell,
  .leaderboard-card {
    grid-column: 1;
  }

  .leaderboard-card {
    position: static;
  }
}

.live-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--accent);
  font-family: var(--ui-font);
  font-size: 0.73rem;
  font-weight: 700;
  text-transform: uppercase;
}

.live-label::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accent);
}

.reset-countdown {
  display: block;
  margin-top: 6px;
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 0.74rem;
  line-height: 1.4;
}

.leaderboard-scroll {
  max-height: 220px;
  overflow-y: auto;
  padding-right: 5px;
  scrollbar-color: var(--accent) color-mix(in srgb, var(--line) 65%, transparent);
  scrollbar-width: thin;
}

.leaderboard-card .leaderboard-scroll {
  flex: 0 1 auto;
  max-height: 312px;
  min-height: 0;
}

.leaderboard-table,
.word-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--ui-font);
}

.leaderboard-table th,
.leaderboard-table td,
.word-table th,
.word-table td {
  border-bottom: 1px solid var(--line);
  padding: 13px 10px;
  text-align: left;
}

.leaderboard-table th,
.leaderboard-table td {
  padding: 7px 4px;
  font-size: 0.76rem;
}

.leaderboard-more {
  margin: 8px 0 0;
  font-family: var(--ui-font);
  font-size: 0.7rem;
  line-height: 1.3;
}

.leaderboard-table td:nth-child(3),
.leaderboard-table td:nth-child(4),
.word-table td:nth-child(1),
.word-table td:nth-child(4) {
  font-variant-numeric: tabular-nums;
}

.content-page {
  padding: 48px 0;
}

.content-grid {
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 36px;
}

.toc {
  position: sticky;
  top: 100px;
  align-self: start;
  border-top: 1px solid var(--line);
  padding-top: 16px;
}

.toc a {
  display: block;
  margin: 12px 0;
  color: var(--muted);
  font-family: var(--ui-font);
}

.article {
  max-width: 880px;
}

.article h1 {
  margin-bottom: 22px;
  font-size: clamp(2.8rem, 6vw, 6rem);
}

.article h2 {
  margin-top: 42px;
  font-size: clamp(1.5rem, 2.2vw, 2.35rem);
  line-height: 1.08;
}

.leaderboard-page {
  display: grid;
  gap: 26px;
}

.leaderboard-hero {
  max-width: none;
  border-top: 3px double var(--ink);
  border-bottom: 1px solid var(--line);
  padding: 26px 0;
}

.leaderboard-hero h1 {
  max-width: none;
  margin: 0;
  font-size: clamp(3rem, 6vw, 6.5rem);
  line-height: 0.95;
}

.leaderboard-hero p {
  max-width: 980px;
  margin: 24px 0 0;
  font-size: clamp(1.08rem, 1.6vw, 1.35rem);
}

.word-articles {
  display: grid;
  gap: 14px;
}

.word-card {
  border-top: 1px solid var(--line);
  padding: 18px 0;
}

.word-card-top {
  display: flex;
  gap: 14px;
  align-items: baseline;
}

.word-card-top span {
  color: var(--accent);
  font-family: var(--ui-font);
  font-variant-numeric: tabular-nums;
}

.how-grid {
  margin-top: 18px;
}

.how-card h3 {
  margin-bottom: 10px;
  font-size: 1.2rem;
}

.how-card p {
  margin: 0;
}

.example-panel {
  margin-top: 16px;
}

.example-panel h3 {
  margin: 10px 0 16px;
}

.example-choices {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 220px));
  gap: 10px;
  margin: 14px 0;
}

.example-choices span {
  display: grid;
  min-height: 42px;
  place-items: center;
  border: 1px solid var(--line);
  border-radius: 8px;
  color: var(--ink);
}

.example-choices .correct-example {
  border-color: color-mix(in srgb, #668c3a 70%, var(--line));
  background: #e8f2de;
  color: #18350d;
}

.rule-list {
  display: grid;
  gap: 10px;
  margin: 18px 0 0;
  padding-left: 22px;
}

.rule-list li {
  color: var(--muted);
  line-height: 1.65;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.wide-panel {
  grid-column: 1 / -1;
}

.faq-list {
  display: grid;
  gap: 12px;
}

.faq-item {
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.faq-item summary {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 18px 20px;
  color: var(--ink);
  cursor: pointer;
  font-size: 1.18rem;
  font-weight: 700;
  list-style: none;
}

.faq-item summary::-webkit-details-marker {
  display: none;
}

.faq-item summary::before {
  content: "";
  width: 0;
  height: 0;
  border-top: 7px solid transparent;
  border-bottom: 7px solid transparent;
  border-left: 10px solid var(--accent);
  transform: translateY(1px);
}

.faq-item[open] summary::before {
  transform: rotate(90deg) translateX(1px);
}

.faq-item p {
  margin: 0;
  padding: 0 20px 20px 42px;
}

.miss-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px 20px;
  margin: 14px 0 0;
  padding-left: 20px;
}

.miss-list li {
  padding-bottom: 8px;
  border-bottom: 1px solid var(--line);
}

.miss-list span {
  display: block;
  font-weight: 700;
}

.miss-list small {
  color: var(--muted);
  font-family: var(--ui-font);
}

.site-footer {
  display: grid;
  gap: 18px;
  justify-items: center;
  margin-top: 42px;
  padding: 38px 18px 28px;
  border-top: 1px solid var(--line);
  background: color-mix(in srgb, var(--panel) 62%, transparent);
  text-align: center;
}

.footer-nav {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px 30px;
  max-width: 920px;
}

.footer-nav a {
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 1rem;
  font-weight: 400;
}

.footer-bottom {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  width: min(760px, 100%);
  border-top: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
  padding-top: 22px;
}

.footer-brand-mark {
  flex: 0 0 auto;
}

.footer-bottom p {
  margin: 0;
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 0.95rem;
  line-height: 1.55;
}

.note {
  color: var(--muted);
  font-family: var(--ui-font);
  font-size: 0.92rem;
}

@media (max-width: 860px) {
  .site-header {
    position: sticky;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 10px;
    padding: 10px 14px;
  }

  .brand {
    min-width: 0;
  }

  .brand-mark {
    width: 34px;
    height: 34px;
    border-radius: 7px;
  }

  .brand-mark span {
    font-size: 1.15rem;
  }

  .brand-mark i {
    right: 6px;
    bottom: 4px;
    font-size: 0.82rem;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    display: none;
  }

  .desktop-nav {
    display: none;
  }

  .mobile-menu {
    display: block;
    position: relative;
  }

  .content-grid,
  .play-layout {
    grid-template-columns: 1fr;
  }

  .play-layout {
    width: min(100% - 28px, 1280px);
    margin: 0 auto;
    gap: 16px;
  }

  .play-layout > .quiz-shell,
  .leaderboard-card {
    grid-column: 1;
  }

  .leaderboard-card {
    position: static;
  }

  .choices {
    grid-template-columns: 1fr;
    justify-content: stretch;
  }

  .form-row {
    flex-direction: column;
    align-items: stretch;
  }

  .form-row input {
    flex: 1 1 auto;
    width: 100%;
  }

  .finish-note {
    white-space: normal;
  }

  .share-overlay {
    padding: 14px;
  }

  .share-modal {
    border-radius: 14px;
    padding: 24px 16px;
  }

  .share-card {
    padding: 20px;
  }

  .share-score-row {
    grid-template-columns: 1fr;
  }

  .share-tools,
  .share-socials {
    gap: 8px;
  }

  .hero-copy {
    padding: 14px 0;
  }

  .hero-line {
    font-size: clamp(1.08rem, 4.4vw, 1.45rem);
    white-space: normal;
  }

  .start-panel {
    min-height: 170px;
    justify-items: center;
    text-align: center;
  }

  .start-button {
    width: min(320px, 100%);
  }

  .stats-grid,
  .miss-list {
    grid-template-columns: 1fr;
  }

  .grid-3,
  .stats-row {
    grid-template-columns: 1fr;
  }

  .example-choices {
    grid-template-columns: 1fr;
  }

  .site-footer,
  .section-header,
  .quiz-top {
    align-items: stretch;
    grid-template-columns: 1fr;
    flex-direction: column;
  }

  h2 {
    font-size: clamp(1.1rem, 5.6vw, 1.72rem);
    line-height: 1.04;
    white-space: nowrap;
  }

  .quiz-title {
    font-size: clamp(1.28rem, 7.2vw, 1.95rem);
    white-space: nowrap;
  }

  .start-prompt {
    max-width: 300px;
    margin-inline: auto;
    font-size: clamp(1.35rem, 7vw, 2rem);
    line-height: 1.08;
  }

  .section-header {
    gap: 12px;
  }

  .section-header .secondary-button {
    width: fit-content;
    max-width: 100%;
    min-height: 38px;
    padding: 0 14px;
    align-self: start;
    font-size: 0.9rem;
  }

  .site-footer {
    gap: 16px;
    padding: 30px 16px 24px;
  }

  .footer-nav {
    gap: 10px 18px;
    max-width: 360px;
  }

  .footer-nav a {
    font-size: 0.9rem;
  }

  .footer-bottom {
    align-items: center;
    gap: 10px;
    padding-top: 18px;
  }

  .footer-bottom p {
    font-size: 0.82rem;
  }
}

@media (max-width: 560px) {
  .hero {
    padding-top: 12px;
  }

  .hero-line {
    font-size: clamp(1rem, 5vw, 1.28rem);
  }

  .quiz-shell,
  .leaderboard-card,
  .panel {
    padding: 14px;
  }

  .quiz-title {
    font-size: clamp(1.18rem, 6.3vw, 1.7rem);
    white-space: nowrap;
  }

  h2 {
    font-size: clamp(1rem, 5vw, 1.45rem);
    white-space: nowrap;
  }

  .quiz-word {
    font-size: clamp(1.35rem, 7vw, 1.95rem);
  }

  .mobile-menu button {
    width: 38px;
    min-height: 38px;
  }

  .article h1,
  .leaderboard-hero h1 {
    font-size: clamp(2.15rem, 12vw, 3.4rem);
    line-height: 0.98;
  }

  .article h2 {
    font-size: clamp(1.35rem, 7vw, 1.85rem);
    white-space: normal;
  }

  .faq-item summary {
    padding: 15px 14px;
    font-size: 1rem;
  }

  .faq-item p {
    padding: 0 14px 16px 34px;
    font-size: 0.95rem;
  }
}
